# OpenAI API Key (for task parsing)
OPENAI_API_KEY=sk-...

# Postgres connection string for durable cloud state (goals, projects,
# priorities, history, AI context + today's plan).
# On Railway: add a Postgres service, then set this on the app service to
# ${{ Postgres.DATABASE_URL }}. Leave unset locally to run on localStorage only.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Shared password gate. When set, the whole app sits behind a single
# password (entered at /login). Leave unset to disable the gate (e.g. local dev).
APP_PASSWORD=choose-a-password
